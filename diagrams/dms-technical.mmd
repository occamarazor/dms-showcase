%% =========================================
%% DMS SaaS — Technical Architecture View
%% =========================================
flowchart LR
    %% Clients
    WEB["Web App (React)"]
    MOBILE["Mobile App (React Native)"]
    EXT["External APIs / Webhooks"]

    %% Infrastructure
    LB["Load Balancer (Hetzner)"]
    GATEWAY["NGINX Gateway / Ingress"]

    %% Security
    AUTH["JWT Auth (NestJS Guards)"]
    RATE["Rate Limiting / WAF"]

    %% Application Layer
    API["NestJS REST API (Use Case Layer)"]

    %% Domain Services
    SALES["Sales Domain"]
    FIN["Financing Domain"]
    DOC["Document Domain"]
    ACC["Accounting Domain"]
    OPS["Dealer Ops Domain"]

    %% Persistence
    DB["PostgreSQL (Schema-per-tenant / ACID)"]
    READ["PostgreSQL Read Replica (Reporting)"]
    CACHE["Redis Cache / Queue"]
    OBJ["S3-Compatible Object Storage"]

    %% Observability
    OBS["Logging / Metrics / Monitoring"]

    %% Flow
    WEB --> LB
    MOBILE --> LB
    EXT --> LB

    LB --> GATEWAY
    GATEWAY --> API

    GATEWAY --> RATE
    API --> AUTH

    API --> SALES
    API --> FIN
    API --> DOC
    API --> ACC
    API --> OPS

    SALES --> DB
    FIN --> DB
    DOC --> DB
    ACC --> DB
    OPS --> DB

    FIN --> CACHE
    SALES --> CACHE

    DOC --> OBJ

    DB --> READ

    %% Observability (outbound only)
    LB -.-> OBS
    GATEWAY -.-> OBS
    API -.-> OBS
    SALES -.-> OBS
    FIN -.-> OBS
    DOC -.-> OBS
    ACC -.-> OBS
    OPS -.-> OBS

    %% Shapes
    LB@{ shape: stadium }
    GATEWAY@{ shape: stadium }
    AUTH@{ shape: hex }
    RATE@{ shape: hex }
    API@{ shape: rounded }
    SALES@{ shape: trap-b }
    FIN@{ shape: trap-b }
    DOC@{ shape: trap-b }
    ACC@{ shape: trap-b }
    OPS@{ shape: trap-b }
    DB@{ shape: cyl }
    READ@{ shape: cyl }
    CACHE@{ shape: h-cyl }
    OBJ@{ shape: cyl }
    OBS@{ shape: lean-r }

    %% Classes
    class WEB client
    class MOBILE client
    class EXT client
    class LB infra
    class GATEWAY infra
    class AUTH sec
    class RATE sec
    class API app
    class SALES domain
    class FIN domain
    class DOC domain
    class ACC domain
    class OPS domain
    class DB storage
    class READ storage
    class CACHE storage
    class OBJ storage
    class OBS obs

    %% Palette
    classDef client fill:#ffe6e6,stroke:#d0021b,color:#424242;
    classDef infra fill:#e6f0ff,stroke:#4a90e2,color:#424242;
    classDef sec fill:#ccd9ff,stroke:#003399,color:#424242;
    classDef app fill:#ffeacc,stroke:#ff6d00,color:#424242;
    classDef domain fill:#fff2cc,stroke:#f5a623,color:#424242;
    classDef storage fill:#e6f7e6,stroke:#7ed321,color:#424242;
    classDef obs fill:#f9e6ff,stroke:#9013fe,color:#424242;