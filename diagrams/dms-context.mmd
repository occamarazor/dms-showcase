%% =========================================
%% C4 Level 1 — Context
%% System actors + external systems
%% =========================================
flowchart LR

%% =========================================
%% ACTORS
%% =========================================

%% ---- Customers ----
ANON["Anonymous Visitor"]
CUSTOMER["Registered Customer"]
%% ---- Tenant-Level ----
SALES["Sales Agent"]
DEALER_ADMIN["Dealer Administrator"]
%% ---- Platform-Level ----
PLATFORM_ADMIN["Platform Administrator"]
SUPPORT["Support Engineer"]

%% =========================================
%% CORE PLATFORM
%% =========================================

DMS["DMS SaaS Platform"]

%% =========================================
%% EXTERNAL SYSTEMS
%% =========================================

%% ---- Financial Systems ----
BANKS["Loan Providers / Banks"]
INSURANCE["Insurance Providers"]

%% ---- Payment Gateways ----
PAYMENT["Payment Gateway"]

%% ---- Government / Vehicle Registries ----
VEHICLE_REG["Vehicle Registry"]

%% ---- eSignature Providers ----
ESIGN["eSignature Service"]

%% =========================
%% INTERACTIONS
%% =========================

%% ---- Actors ----
ANON -->|Browses listings<br>Saves favourites| DMS
CUSTOMER -->|Applies for financing<br>Selects insurance<br>Signs contract| DMS
SALES -->|Creates offers<br>Submits financing<br>Generates contracts| DMS
DEALER_ADMIN -->|Manages dealership<br>Inventory<br>Staff| DMS
PLATFORM_ADMIN -->|Creates tenants<br>Assigns SaaS tiers| DMS
SUPPORT -->|Investigates incidents<br>Tenant diagnostics| DMS

%% ---- External Systems ----
DMS -->|Submits loan applications<br>Receives approval| BANKS
DMS -->|Requests insurance quotes<br>Issues policies| INSURANCE
DMS -->|Processes payments| PAYMENT
DMS -->|Verifies VIN<br>Submits registration| VEHICLE_REG
DMS -->|Sends contracts for signing<br>Receives signed docs| ESIGN

%% =========================
%% SHAPES
%% =========================
DMS@{ shape: rounded }

%% =========================
%% CLASSES
%% =========================

class ANON,CUSTOMER,SALES,DEALER_ADMIN,PLATFORM_ADMIN,SUPPORT actor
class DMS app
class BANKS,INSURANCE,PAYMENT,VEHICLE_REG,ESIGN external

%% =========================
%% PALETTE (LEGEND)
%% =========================

classDef app fill:#ffeacc,stroke:#ff6d00,color:#424242;
classDef actor fill:#fff0f0,stroke:#d0021b,stroke-dasharray:4 4,color:#424242;
classDef external fill:#f5f5f5,stroke:#6b6b6b,stroke-dasharray: 5 5,color:#424242;
