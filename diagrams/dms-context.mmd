%% =========================================
%% C4 Level 1 — Context
%% System actors + external systems
%% =========================================
flowchart LR

%% =========================================
%% ACTORS
%% =========================================

%% ---- Customers ----
ANON["Anonymous Visitor"]
CUSTOMER["Registered Customer"]
%% ---- Tenant-Level ----
SALES["Sales Agent"]
DEALER_ADMIN["Dealer Administrator"]
%% ---- Platform-Level ----
PLATFORM_ADMIN["Platform Administrator"]
SUPPORT["Support Engineer"]

%% =========================================
%% CORE PLATFORM
%% =========================================

DMS["DMS SaaS Platform"]

%% =========================================
%% EXTERNAL SYSTEMS
%% =========================================

%% ---- Financial Systems ----
BANKS["Loan Providers / Banks"]
INSURANCE["Insurance Providers"]

%% ---- Payment Gateways ----
PAYMENT["Payment Gateway"]

%% ---- Government / Vehicle Registries ----
VEHICLE_REG["Vehicle Registry"]

%% ---- eSignature Providers ----
ESIGN["eSignature Service"]

%% =========================
%% INTERACTIONS
%% =========================

%% ---- Actors ----
ANON -->|Browse listings<br>Save favourites| DMS
CUSTOMER -->|Apply for financing<br>Select insurance<br>Sign contract| DMS
SALES -->|Create offers<br>Submit financing<br>Generate contracts| DMS
DEALER_ADMIN -->|Manage dealership<br>Inventory<br>Staff| DMS
PLATFORM_ADMIN -->|Create tenants<br>Assign SaaS tiers| DMS
SUPPORT -->|Investigate incidents<br>Tenant diagnostics| DMS

%% ---- External Systems ----
DMS -->|Submit loan applications<br>Receive approval| BANKS
DMS -->|Request insurance quotes<br>Issue policies| INSURANCE
DMS -->|Process payments| PAYMENT
DMS -->|Verify VIN<br>Submit registration| VEHICLE_REG
DMS -->|Send contracts for signing<br>Receive signed docs| ESIGN

%% =========================
%% SHAPES
%% =========================
DMS@{ shape: rounded }

%% =========================
%% CLASSES
%% =========================

class ANON,CUSTOMER,SALES,DEALER_ADMIN,PLATFORM_ADMIN,SUPPORT actor
class DMS app
class BANKS,INSURANCE,PAYMENT,VEHICLE_REG,ESIGN external

%% =========================
%% PALETTE (LEGEND)
%% =========================

classDef app fill:#ffeacc,stroke:#ff6d00,color:#424242;
classDef actor fill:#fff0f0,stroke:#d0021b,stroke-dasharray:4 4,color:#424242;
classDef external fill:#f5f5f5,stroke:#6b6b6b,stroke-dasharray: 5 5,color:#424242;
