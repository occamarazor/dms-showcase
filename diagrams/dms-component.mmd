%% C4 Level 3 — Component Diagram
%% Core API (NestJS Modular Monolith)
%% =========================================
flowchart TB

%% =========================================
%% EXTERNAL CONTAINERS & SYSTEMS (direct interaction)
%% =========================================

POSTGRES["**Relational Database**<br>PostgreSQL"]
REDIS["**Cache + Job Queue**<br>Redis"]
INTEGRATION["**Integration Service**<br>NestJS microservice"]
