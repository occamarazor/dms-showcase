POSTGRES@{ shape: cyl }
REDIS@{ shape: h-cyl }
INTEGRATION@{ shape: trap-b }
AUTH_PROVIDER@{ shape: hex }


%% ===== CONTAINER BOUNDARY START =====
subgraph CORE_API["Core API"]

%% =========================================
%% SECURITY / POLICY
%% =========================================

AUTH_GUARD["
**JWT Auth**
NestJS Guard
<br>
- Validates JWT tokens
- Enforces authenticated access
"]

RBAC_GUARD["
**RBAC**
NestJS Guard
<br>
- Enforces role permissions
- Applies platform access policies
"]

TENANT_RESOLVER["
**Tenant Resolver**
NestJS Middleware
<br>
- Extracts tenant from JWT
- Injects tenant context
- Resolves DB schema
"]

TX_MANAGER["
**Transaction Manager**
NestJS Interceptor
<br>
- Opens DB transaction
- Ensures atomic use-case execution
- Commits / rollbacks state
"]

class AUTH_GUARD,RBAC_GUARD,TENANT_RESOLVER,TX_MANAGER sec

AUTH_GUARD@{ shape: hex }
RBAC_GUARD@{ shape: hex }
TENANT_RESOLVER@{ shape: hex }
TX_MANAGER@{ shape: hex }

%% =========================================
%% APPLICATION LAYER
%% =========================================

CONTROLLERS["
**REST Endpoints**
NestJS Controllers
<br>
- Exposes REST endpoints
- Validates request DTOs
- Maps requests to use-cases
"]

USE_CASES["
**Use Case Orchestrators**
NestJS Services
<br>
- Orchestrates use-cases
- Coordinates domain modules
- Triggers async workflows
"]

class CONTROLLERS app
class USE_CASES app

CONTROLLERS@{ shape: rounded }
USE_CASES@{ shape: rounded }

%% =========================================
%% DOMAIN MODULES
%% =========================================

SALES["
**Sales Module**
NestJS Module
<br>
- Manages vehicle offers
- Tracks sales lifecycle
- Enforces sales invariants
"]

FINANCING["
**Financing Module**
NestJS Module
<br>
- Submits loan applications
- Tracks approval states
- Enforces financing rules
"]

ACCOUNTING["
**Accounting Module**
NestJS Module
<br>
- Generates invoices
- Maintains ledger entries
- Ensures financial integrity
"]

DEALER_OPS["
**Dealer Operations Module**
NestJS Module
<br>
- Manages dealership data
- Manages staff & permissions
- Tracks inventory
"]

class SALES,FINANCING,ACCOUNTING,DEALER_OPS domain

SALES@{ shape: trap-b }
FINANCING@{ shape: trap-b }
ACCOUNTING@{ shape: trap-b }
DEALER_OPS@{ shape: trap-b }

%% =========================================
%% INFRASTRUCTURE ADAPTERS
%% =========================================

REPOSITORIES["
**Repository Layer**
ORM Adapters
<br>
- Persists domain entities
- Executes tenant-scoped queries
- Maps entities to database
"]

CACHE_ADAPTER["
**Cache Adapter**
Redis Client
<br>
- Caches frequently read aggregates
- Reduces DB load
"]

EVENT_PUBLISHER["
**Async Event Publisher**
BullMQ Producer
<br>
- Publishes background jobs
- Triggers async workflows
"]

INTEGRATION_CLIENT["
**Integration Client**
HTTP Client Adapter
<br>
- Calls Integration Service APIs
- Delegates external workflows
"]

class REPOSITORIES,CACHE_ADAPTER,EVENT_PUBLISHER,INTEGRATION_CLIENT infra

REPOSITORIES@{ shape: stadium }
CACHE_ADAPTER@{ shape: stadium }
EVENT_PUBLISHER@{ shape: stadium }
INTEGRATION_CLIENT@{ shape: stadium }

end
%% ===== CONTAINER BOUNDARY END =====


%% =========================================
%% INTERACTIONS
%% =========================================

%% ---- Components ----
CONTROLLERS -->|"Validates access<br>Sync | Guard"| AUTH_GUARD
AUTH_GUARD -->|"Checks role permissions<br>Sync | Guard"| RBAC_GUARD
RBAC_GUARD -->|"Resolves tenant context<br>Sync | Middleware"| TENANT_RESOLVER
TENANT_RESOLVER -->|"Opens transactional scope<br>Sync | Interceptor"| TX_MANAGER
TX_MANAGER -->|"Executes application use-case<br>Sync | Method call"| USE_CASES

USE_CASES -->|"Invokes domain logic<br>Sync | Method call"| SALES
USE_CASES -->|"Invokes domain logic<br>Sync | Method call"| FINANCING
USE_CASES -->|"Invokes domain logic<br>Sync | Method call"| ACCOUNTING
USE_CASES -->|"Invokes domain logic<br>Sync | Method call"| DEALER_OPS

SALES -->|"Persists aggregates<br>Sync | ORM query"| REPOSITORIES
FINANCING -->|"Persists aggregates<br>Sync | ORM query"| REPOSITORIES
ACCOUNTING -->|"Persists financial state<br>Sync | ORM query"| REPOSITORIES
DEALER_OPS -->|"Persists operational state<br>Sync | ORM query"| REPOSITORIES

USE_CASES -->|"Caches read models<br>Sync | Redis"| CACHE_ADAPTER
USE_CASES -->|"Publishes background job<br>Async | BullMQ"| EVENT_PUBLISHER
USE_CASES -->|"Delegats external workflow<br>Sync | HTTP REST"| INTEGRATION_CLIENT

%% ---- Containers ----
AUTH_GUARD -->|"Verifies JWT signature<br>Sync | HTTPS"| AUTH_PROVIDER
REPOSITORIES -->|"Reads/writes tenant data<br>Sync | PostgreSQL"| POSTGRES
CACHE_ADAPTER -->|"Reads/writes cache<br>Sync | Redis"| REDIS
EVENT_PUBLISHER -->|"Publishes async jobs<br>Async | Redis queue"| REDIS
INTEGRATION_CLIENT -->|"Sends integration command<br>Sync | HTTP REST"| INTEGRATION

