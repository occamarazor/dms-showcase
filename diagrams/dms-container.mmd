%% =========================================
%% C4 Level 2 — Container Diagram
%% High-level technology + communications
%% =========================================
flowchart LR

%% ===== SYSTEM BOUNDARY START =====
subgraph PLATFORM["DMS SaaS Platform"]
    %% =========================================
    %% CLIENTS
    %% =========================================

    CLIENT["
    **Dealer Web App**
    React SPA
    <br>
    - Dealer UI
    - Forms, dashboards, reports
    - Sends API requests
    - Displays operational data
    "]

    class CLIENT client

    %% =========================================
    %% INFRASTRUCTURE
    %% =========================================

    %% ---- Load balancer ----%%
    LB["
    **Load Balancer**
    Hetzner
    <br>
    - Exposes public endpoint
    - Terminates TLS
    - Performs health checks
    - Distributes traffic
    "]

    class LB infra
    LB@{ shape: stadium }

    %% ---- API Gateway ----%%
    GATEWAY["
    **API Gateway**
    NGINX Reverse Proxy
    <br>
    - Routes API requests
    - Applies rate limits
    - Logs access traffic
    - Forwards upstream requests
    "]

    class GATEWAY infra
    GATEWAY@{ shape: stadium }

    %% =========================================
    %% SECURITY
    %% =========================================

    AUTH["
    **Identity Provider**
    OAuth2 / JWT
    (Keycloak/Auth0)
    <br>
    - Authenticates users
    - Issuance JWT tokens
    - Enforces RBAC policies
    "]

    class AUTH sec
    AUTH@{ shape: hex }

    %% =========================================
    %% APPLICATION
    %% =========================================

    %% ---- Core API ----%%
    API["
    **Core API**
    NestJS Modular Monolith
    <br>
    - Sales management
    - Financing workflows
    - Accounting transactions
    - Dealer operations
    - Enforces business rules
    - Publishes domain events
    "]

    class API app
    API@{ shape: rounded }

    %% ---- Background Worker ----%%
    WORKER["
    **Background Worker**
    NestJS + BullMQ
    <br>
    - Consumes async jobs
    - Retries failed tasks
    - Dispatches service calls
    - Executes background workflows
    "]

    class WORKER app
    WORKER@{ shape: rounded }

    %% =========================================
    %% MICROSERVICES
    %% =========================================

    %% ---- Integration Service ----%%
    INTEGRATION["
    **Integration Service**
    NestJS microservice
    <br>
    - Sends bank requests
    - Sends insurance requests
    - Executes payment requests
    - Applies retry policies
    - Implements circuit breakers
    "]

    class INTEGRATION domain
    INTEGRATION@{ shape: trap-b }

    %% ---- Notification Service ----%%
    NOTIFY["
    **Notification Service**
    NestJS microservice
    <br>
    - Sends email notifications
    - Sends SMS messages
    - Manages templates
    - Retries failed deliveries
    "]

    class NOTIFY domain
    NOTIFY@{ shape: trap-b }

    %% ---- Document Service ----%%
    DOCS["
    **Document Service**
    NestJS microservice
    <br>
    - Generates PDF contracts
    - Prepares signature requests
    - Manages document lifecycle
    "]

    class DOCS domain
    DOCS@{ shape: trap-b }

    %% =========================================
    %% DATA STORES
    %% =========================================

    %% ---- Relational ----%%
    POSTGRES["
    **Relational Database**
    PostgreSQL
    <br>
    - Stores transactional data
    - Maintains tenant schemas
    - Enforces ACID guarantees
    "]

    class POSTGRES storage
    POSTGRES@{ shape: cylinder }

    %% ---- In-memory ----%%
    REDIS["
    **Cache & Job Queue**
    Redis
    <br>
    - Stores cached aggregates
    - Queues async jobs
    - Coordinates background processing
    "]

    class REDIS storage
    REDIS@{ shape: h-cyl }

    %% ---- Object ----%%
    OBJECTS["
    **S3 Object Storage**
    Hetzner
    <br>
    - Stores generated contracts
    - Stores uploaded documents
    - Serves document downloads
    "]

    class OBJECTS storage
    OBJECTS@{ shape: cylinder }

    %% =========================================
    %% OBSERVABILITY
    %% =========================================

    %% ---- Metrics ----
    OBS_METRICS["
    **Metrics Platform**
    Prometheus + Grafana
    <br>
    - Collects system metrics
    - Scrapes service telemetry
    - Provides monitoring dashboards
    "]

    class OBS_METRICS obs
    OBS_METRICS@{ shape: lean-r }

    %% ---- Logs ----
    OBS_LOGS["
    **Log Aggregation**
    Grafana Loki
    <br>
    - Aggregates application logs
    - Stores structured logs
    - Enables log exploration
    "]

    class OBS_LOGS obs
    OBS_LOGS@{ shape: lean-r }
end
%% ===== SYSTEM BOUNDARY END =====

%% =========================================
%% ACTORS
%% =========================================

ANON["Anonymous Visitor"]
CUSTOMER["Registered Customer"]
SALES["Sales Agent"]
DEALER_ADMIN["Dealer Administrator"]
PLATFORM_ADMIN["Platform Administrator"]
SUPPORT["Support Engineer"]

class ANON,CUSTOMER,SALES,DEALER_ADMIN,PLATFORM_ADMIN,SUPPORT actor

%% =========================================
%% EXTERNAL SYSTEMS
%% =========================================

BANK["Bank APIs"]
INSURANCE["Insurance APIs"]
PAYMENT["Payment Provider"]
ESIGN["eSignature Platform"]

class BANK,INSURANCE,PAYMENT,ESIGN external

%% =========================================
%% INTERACTIONS
%% =========================================

%% ---- Containers ----
CLIENT -->|"Sends API requests | Sync | HTTPS | :443"| LB
LB -->|"Forwards traffic | Sync | HTTP | :80"| GATEWAY
GATEWAY -->|"Routes API requests | Sync | HTTP REST | :8080"| API

API -->|"Validates identity tokens | Sync | HTTPS | :443"| AUTH

API -->|"Reads/writes transactional data | Sync | PostgreSQL | :5432"| POSTGRES
API -->|"Reads/writes cached data | Sync | Redis | :6379"| REDIS

API -->|"Publishes domain events | Async message | Redis queue | :6379"| REDIS
WORKER -->|"Consumes background jobs | Async message | Redis queue | :6379"| REDIS

API -->|"Sends integration requests | Sync | HTTP REST | :3003"| INTEGRATION

WORKER -->|"Sends notification commands | Sync | HTTP REST | :3001"| NOTIFY
WORKER -->|"Requests document generation | Sync | HTTP REST | :3002"| DOCS

DOCS -->|"Stores generated documents | Object API | HTTPS | :443"| OBJECTS

%% ---- Metrics ----
GATEWAY -.->|"Exports gateway metrics | Prometheus scrape | HTTP | :9113"| OBS_METRICS
API -.->|"Exposes application metrics | Prometheus scrape | HTTP | :9464"| OBS_METRICS
WORKER -.->|"Exposes worker metrics | Prometheus scrape | HTTP | :9464"| OBS_METRICS
NOTIFY -.->|"Exposes service metrics | Prometheus scrape | HTTP | :9464"| OBS_METRICS
DOCS -.->|"Exposes service metrics | Prometheus scrape | HTTP | :9464"| OBS_METRICS
INTEGRATION -.->|"Exposes service metrics | Prometheus scrape | HTTP | :9464"| OBS_METRICS

%% ---- Logs ----
API -.->|"Ships application logs | Push | HTTP | :3100"| OBS_LOGS
WORKER -.->|"Ships worker logs | Push | HTTP | :3100"| OBS_LOGS
GATEWAY -.->|"Ships access logs | Push | HTTP | :3100"| OBS_LOGS
NOTIFY -.->|"Ships service logs | Push | HTTP | :3100"| OBS_LOGS
DOCS -.->|"Ships service logs | Push | HTTP | :3100"| OBS_LOGS
INTEGRATION -.->|"Ships service logs | Push | HTTP | :3100"| OBS_LOGS

%% ---- Actors ----
ANON -->|"Browses listings | Sync | HTTPS | :443"| CLIENT
CUSTOMER -->|"Manages purchasing | Sync | HTTPS | :443"| CLIENT
SALES -->|"Operates sales | Sync | HTTPS | :443"| CLIENT
DEALER_ADMIN -->|"Administers operations | Sync | HTTPS | :443"| CLIENT
PLATFORM_ADMIN -->|"Manages tenants | Sync | HTTPS | :443"| CLIENT
SUPPORT -->|"Accesses diagnostics | Sync | HTTPS | :443"| CLIENT

%% ---- External Integrations ----
INTEGRATION -->|"Requests loan processing  | Sync | HTTPS | :443"| BANK
INTEGRATION -->|"Requests insurance quotes | Sync | HTTPS | :443"| INSURANCE
INTEGRATION -->|"Executes payment transaction | Sync | HTTPS | :443"| PAYMENT
INTEGRATION -->|"Creates signature requests | Sync | HTTPS | :443"| ESIGN

